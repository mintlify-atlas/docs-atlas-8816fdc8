  "keyFeatures": [
    "Multi-database support via plugin system",
    "Secure credential management with OS keyring integration",
    "Interactive query editor with syntax highlighting",
    "Database object browsing with connection trees",
    "Cross-platform desktop application (Windows, macOS, Linux)",
    "Extensible plugin SDK for adding custom database drivers",
    "Multiple result formats (SQL tables, documents, key-value)",
    "Connection testing and validation"
